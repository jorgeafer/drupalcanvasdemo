# Groq API Key (free tier)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the public-facing Drupal URL shown in the chat UI.
# Leave blank when running locally (defaults to http://localhost:8080).
# In GitHub Codespaces this is set automatically via CODESPACE_NAME.
# DRUPAL_PUBLIC_URL=https://my-codespace-name-8080.app.github.dev
