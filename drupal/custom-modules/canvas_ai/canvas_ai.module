<?php

/**
 * @file
 * Canvas AI – AI-powered component-based page builder for Drupal.
 */

use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\field\Entity\FieldConfig;
use Drupal\field\Entity\FieldStorageConfig;
use Drupal\node\Entity\NodeType;

/**
 * Implements hook_install().
 *
 * Creates the canvas_page content type only when the native Drupal Canvas
 * module is NOT installed. With Drupal CMS 2.0 + Canvas, the content type
 * is managed by Canvas itself; this custom type is only for vanilla Drupal.
 */
function canvas_ai_install() {
  // Skip custom content type when native Canvas module is present.
  if (\Drupal::moduleHandler()->moduleExists('canvas')) {
    drupal_flush_all_caches();
    return;
  }

  // Create content type.
  if (!NodeType::load('canvas_page')) {
    NodeType::create([
      'type'              => 'canvas_page',
      'name'              => 'Canvas Page',
      'description'       => 'AI-generated pages composed of visual components.',
      'new_revision'      => FALSE,
      'display_submitted' => FALSE,
    ])->save();
  }

  // Create field storage (shared across bundles).
  if (!FieldStorageConfig::loadByName('node', 'field_canvas_data')) {
    FieldStorageConfig::create([
      'field_name'  => 'field_canvas_data',
      'entity_type' => 'node',
      'type'        => 'text_long',
      'cardinality' => 1,
    ])->save();
  }

  // Attach field to the canvas_page bundle.
  if (!FieldConfig::loadByName('node', 'canvas_page', 'field_canvas_data')) {
    FieldConfig::create([
      'field_name'  => 'field_canvas_data',
      'entity_type' => 'node',
      'bundle'      => 'canvas_page',
      'label'       => 'Canvas Components (JSON)',
      'required'    => FALSE,
    ])->save();
  }

  drupal_flush_all_caches();
}

/**
 * Implements hook_theme().
 */
function canvas_ai_theme($existing, $type, $theme, $path) {
  return [
    // Front-end component renderer for canvas_page nodes.
    'canvas_page_node' => [
      'variables' => [
        'components' => [],
        'node_title' => '',
      ],
      'template' => 'canvas-page-node',
    ],
    // Admin chat page rendered inside Drupal's admin theme.
    'canvas_ai_admin' => [
      'variables' => [],
      'template'  => 'canvas-ai-admin',
    ],
  ];
}

/**
 * Implements hook_toolbar().
 *
 * Adds a "Canvas AI" shortcut to Drupal's admin toolbar.
 */
function canvas_ai_toolbar() {
  return [
    'canvas_ai' => [
      '#type'   => 'toolbar_item',
      '#weight' => 125,
      'tab'     => [
        '#type'       => 'link',
        '#title'      => t('Canvas AI'),
        '#url'        => \Drupal\Core\Url::fromRoute('canvas_ai.admin'),
        '#attributes' => [
          'title' => t('Generate pages with AI'),
          'class' => ['toolbar-icon'],
          'style' => 'background-image:none',
        ],
      ],
      '#cache' => ['contexts' => ['user.permissions']],
    ],
  ];
}

/**
 * Implements hook_node_view().
 *
 * Replaces the default node render with our component renderer for canvas_page.
 */
function canvas_ai_node_view(array &$build, EntityInterface $node, EntityViewDisplayInterface $display, $view_mode) {
  if ($node->bundle() !== 'canvas_page' || $view_mode !== 'full') {
    return;
  }

  $raw = $node->hasField('field_canvas_data')
    ? $node->get('field_canvas_data')->value
    : NULL;

  if (empty($raw)) {
    return;
  }

  $components = json_decode($raw, TRUE);
  if (!is_array($components)) {
    return;
  }

  // Clear out every default field render and replace with our template.
  foreach (array_keys($build) as $key) {
    if (strpos($key, '#') !== 0) {
      unset($build[$key]);
    }
  }

  $build['canvas'] = [
    '#theme'       => 'canvas_page_node',
    '#components'  => $components,
    '#node_title'  => $node->label(),
    '#cache'       => ['max-age' => 0],
  ];
}
