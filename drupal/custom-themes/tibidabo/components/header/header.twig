{#
  Tibidabo Header SDC
  Props: site_name, logo_url, home_url, nav_items[], status_open, status_hours, cta_url, prices_url
#}
<header class="tibi-header" role="banner">
  <div class="tibi-header__inner tibi-container--wide">

    {# Logo #}
    <a href="{{ home_url|default('/') }}" class="tibi-header__logo" aria-label="{{ site_name|default('TIBIDABO') }}">
      {% if logo_url %}
        <img src="{{ logo_url }}" alt="{{ site_name|default('TIBIDABO') }}" class="tibi-header__logo-img">
      {% else %}
        <span class="tibi-header__logo-text">{{ site_name|default('TIBIDABO') }}</span>
      {% endif %}
    </a>

    {# Desktop nav #}
    {% if nav_items is not empty %}
      <nav class="tibi-header__nav" aria-label="Primary navigation">
        {% for item in nav_items %}
          <a href="{{ item.url }}" class="tibi-header__nav-link">{{ item.label }}</a>
        {% endfor %}
      </nav>
    {% endif %}

    {# Desktop actions #}
    <div class="tibi-header__actions">
      <div class="tibi-header__status tibi-header__status--{{ status_open ? 'open' : 'closed' }}">
        <span class="tibi-header__status-dot"></span>
        <span>{{ status_open ? 'Obert' : 'Tancat' }} {{ status_hours }}</span>
      </div>
      <a href="{{ prices_url|default('#precios') }}" class="tibi-btn tibi-btn--outline tibi-btn--md">Veure preus</a>
      <a href="{{ cta_url|default('#tickets') }}" class="tibi-btn tibi-btn--primary tibi-btn--md">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm10 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zM7.82 5l-.94-2H1v2h2l3.6 7.59L5.25 14c-.16.28-.25.61-.25.96C5 16.1 5.9 17 7 17h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63H19c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0 0 23.46 4H5.21l-.94-2H1v2h3.2l.62 1z"/></svg>
        Comprar entrades
      </a>
    </div>

    {# Mobile toggle #}
    <button class="tibi-header__toggle" aria-expanded="false" aria-controls="tibi-mobile-menu" aria-label="Obrir menú">
      <svg class="tibi-header__icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
      <svg class="tibi-header__icon-close" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
    </button>
  </div>

  {# Mobile menu #}
  <div id="tibi-mobile-menu" class="tibi-header__mobile" hidden>
    <nav class="tibi-container--wide">
      <div class="tibi-header__status tibi-header__status--{{ status_open ? 'open' : 'closed' }} tibi-header__status--mobile">
        <span class="tibi-header__status-dot"></span>
        <span>{{ status_open ? 'Obert avui' : 'Tancat avui' }} {{ status_hours }}</span>
      </div>
      {% if nav_items is not empty %}
        {% for item in nav_items %}
          <a href="{{ item.url }}" class="tibi-header__mobile-link">{{ item.label }}</a>
        {% endfor %}
      {% endif %}
      <div class="tibi-header__mobile-ctas">
        <a href="{{ prices_url|default('#precios') }}" class="tibi-btn tibi-btn--outline tibi-btn--md tibi-btn--full">Veure preus</a>
        <a href="{{ cta_url|default('#tickets') }}"    class="tibi-btn tibi-btn--primary tibi-btn--md tibi-btn--full">Comprar entrades</a>
      </div>
    </nav>
  </div>
</header>
