{#
  Tibidabo How To Get SDC
  Props: heading, subheading, transport_options[], map_embed_url
#}
<section class="tibi-howtoget tibi-section tibi-section--light">
  <div class="tibi-container">
    <div class="tibi-section__header">
      <h2 class="tibi-heading-lg">{{ heading|default('Com arribar-hi') }}</h2>
      {% if subheading %}
        <p class="tibi-text-lead">{{ subheading }}</p>
      {% endif %}
    </div>

    <div class="tibi-howtoget__layout">
      <div class="tibi-howtoget__options">
        {% for option in transport_options %}
          <div class="tibi-howtoget__option">
            <div class="tibi-howtoget__icon-wrap">
              {% if option.icon == 'bus' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M4 16c0 .88.39 1.67 1 2.22V20a1 1 0 001 1h1a1 1 0 001-1v-1h8v1a1 1 0 001 1h1a1 1 0 001-1v-1.78A2.99 2.99 0 0020 16V6c0-3.5-3.58-4-8-4s-8 .5-8 4v10zm3.5 1c-.83 0-1.5-.67-1.5-1.5S6.67 14 7.5 14s1.5.67 1.5 1.5S8.33 17 7.5 17zm9 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm1.5-6H6V6h12v5z"/></svg>
              {% elseif option.icon == 'metro' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H4c-1.1 0-2 .9-2 2v16l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-7 13l-3-4.94-3 4.94H5l4-7H7V7h4v1.06L14 13l3-4.94V7h4v1h-2l4 7h-2z"/></svg>
              {% elseif option.icon == 'tram' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17 9.5v-5c0-.28-.22-.5-.5-.5h-9c-.28 0-.5.22-.5.5v5l-2.5 5V20a1 1 0 001 1h1a1 1 0 001-1v-1h10v1a1 1 0 001 1h1a1 1 0 001-1v-5.5L17 9.5zm-7 7c-.83 0-1.5-.67-1.5-1.5S9.17 13.5 10 13.5s1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm4 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM9 5h6v4H9V5zM6 14v-1l1.5-3h9L18 13v1H6z"/></svg>
              {% elseif option.icon == 'car' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"/></svg>
              {% else %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M13.49 5.48c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm-3.6 13.9l1-4.4 2.1 2v6h2v-7.5l-2.1-2 .6-3c1.3 1.5 3.3 2.5 5.5 2.5v-2c-1.9 0-3.5-1-4.3-2.4l-1-1.6c-.4-.6-1-1-1.7-1-.3 0-.5.1-.8.1l-5.2 2.2v4.7h2v-3.4l1.8-.7-1.6 8.1-4.9-1-.4 2 7 1.4z"/></svg>
              {% endif %}
            </div>
            <div class="tibi-howtoget__option-body">
              <h3 class="tibi-howtoget__option-title">{{ option.label }}</h3>
              {% if option.description %}
                <p class="tibi-howtoget__option-desc">{{ option.description }}</p>
              {% endif %}
              {% if option.link_url %}
                <a href="{{ option.link_url }}" class="tibi-card__link">
                  {{ option.link_label|default('Més informació') }}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

      {% if map_embed_url %}
        <div class="tibi-howtoget__map">
          <iframe
            src="{{ map_embed_url }}"
            width="100%"
            height="100%"
            style="border:0"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Mapa de localització del Tibidabo"
          ></iframe>
        </div>
      {% endif %}
    </div>
  </div>
</section>
